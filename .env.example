NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
DEVICE_INGEST_TOKEN=dev-token-change-me
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
TEACHBOX_LLM_MODEL=openai/gpt-oss-120b
TEACHBOX_SAFEGUARD_MODEL=openai/gpt-oss-safeguard-20b
TEACHBOX_STT_MODEL=whisper-large-v3-turbo
TEACHBOX_STT_PROMPT=Important names and spellings: San, SANbox. Use those exact spellings when they are spoken.
TEACHBOX_TTS_MODEL=gemini-2.5-flash-preview-tts
TEACHBOX_TTS_VOICE_NAME=Kore
TEACHBOX_TTS_SPEED=1.15
# Set one Gemini-compatible API key env var for TTS.
GEMINI_API_KEY=your-google-ai-studio-key
# GOOGLE_API_KEY=your-google-ai-studio-key
# GOOGLE_CLOUD_API_KEY=your-google-ai-studio-key
